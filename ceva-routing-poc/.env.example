# Mistral AI key — required for live LLM responses.
# Without it, the Co-Pilot transparently falls back to a deterministic, data-grounded
# answer composed from the current scenario state, so the demo still runs.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
AI_INTELLIGENCE_PATTERN=RAG Pipeline Engineering

# France control-tower configuration.
APP_NAME=CEVA Dynamic Routing Platform
APP_ENV=local
OPERATING_REGION=France
CONTROL_TOWER=CEVA France Control Tower
DEPOT_TIMEZONE=Europe/Paris
CARBON_PRICE_EUR_PER_TONNE=90

# Optional: disable OSRM and use Haversine fallback for distances.
# Set to "0" to disable. Default is enabled.
USE_OSRM=1

# Comma-separated CORS origins allowed to call the FastAPI backend.
CORS_ORIGINS=http://localhost:5173

# Backend port (default 8000)
PORT=8000
